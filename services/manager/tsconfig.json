{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ui-rater/contracts": ["../../packages/contracts/src/index.ts"],
      "@ui-rater/contracts/*": ["../../packages/contracts/src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
