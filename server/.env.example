# Optional: override server/data/sessions with an absolute directory.
UI_RATER_DATA_DIR=
UI_RATER_SESSION_DIR=

# Required outside localhost. Send Authorization: Bearer <token> to admin routes.
UI_RATER_ADMIN_TOKEN=replace-with-a-long-random-admin-token
# Required in production for scoped run/attempt capabilities. Development creates
# an ephemeral local secret when this is omitted.
UI_RATER_CAPABILITY_SECRET=replace-with-at-least-32-random-bytes
