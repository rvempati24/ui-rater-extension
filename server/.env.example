# Required only when POST /api/sessions/<session-id>/analyze is called.
OPENAI_API_KEY=
# Optional override. The baseline defaults to gpt-5.6-terra.
OPENAI_MODEL=gpt-5.6-terra

# Optional: override server/data/sessions with an absolute directory.
UI_RATER_SESSION_DIR=

# Optional synthetic website source root included in analysis/input.json.
# The analyze API never accepts this path from an HTTP request.
UI_RATER_WEBSITE_SOURCE_DIR=

# Set automatically by npm run dev:tasks. Manual starts may point this at
# a ui-rater-website.json file and set an attempt label for trace organization.
UI_RATER_WEBSITE_METADATA_FILE=
UI_RATER_WEBSITE_RUN_ID=
UI_RATER_ATTEMPT=attempt-001
